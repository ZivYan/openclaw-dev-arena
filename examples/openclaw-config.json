{
  "_comment": "OpenClaw 单Agent多职责研发流示例配置 — 对外单入口、对内三角色模型路由",
  "models": {
    "mode": "merge",
    "providers": {
      "anthropic": {
        "baseUrl": "https://api.anthropic.com/v1",
        "apiKey": "<YOUR_ANTHROPIC_API_KEY>",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "<CLAUDE_OPUS_MODEL_ID>",
            "name": "Claude Opus",
            "api": "anthropic-messages",
            "reasoning": true,
            "input": [
              "text",
              "image"
            ],
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      },
      "openai": {
        "baseUrl": "https://api.openai.com/v1",
        "apiKey": "<YOUR_OPENAI_API_KEY>",
        "api": "responses",
        "models": [
          {
            "id": "<CODEX_MODEL_ID>",
            "name": "Codex",
            "api": "responses",
            "reasoning": true,
            "input": [
              "text",
              "image"
            ],
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "<GPT54_MODEL_ID>",
            "name": "GPT-5.4",
            "api": "responses",
            "reasoning": true,
            "input": [
              "text",
              "image"
            ],
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "fallbacks": []
      },
      "models": {
        "anthropic/<CLAUDE_OPUS_MODEL_ID>": {
          "alias": "review"
        },
        "openai/<CODEX_MODEL_ID>": {
          "alias": "code"
        },
        "openai/<GPT54_MODEL_ID>": {
          "alias": "delivery"
        }
      },
      "workspace": "/home/user/.openclaw/workspace",
      "memorySearch": {
        "enabled": true,
        "provider": "local",
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3
          }
        }
      },
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    },
    "list": [
      {
        "id": "rd-lead",
        "default": true,
        "workspace": "/home/user/.openclaw/workspace-rd-lead",
        "model": {
          "primary": "anthropic/<CLAUDE_OPUS_MODEL_ID>",
          "fallbacks": []
        },
        "heartbeat": {
          "every": "30m",
          "target": "last"
        },
        "name": "RD Lead",
        "tools": {
          "allow": [
            "read",
            "message",
            "web_search",
            "web_fetch",
            "session_status",
            "sessions_list",
            "sessions_history",
            "sessions_send",
            "sessions_spawn"
          ]
        }
      },
      {
        "id": "rd-coder",
        "name": "RD Coder",
        "workspace": "/home/user/.openclaw/workspace-rd-coder",
        "model": {
          "primary": "openai/<CODEX_MODEL_ID>",
          "fallbacks": []
        },
        "tools": {
          "allow": [
            "exec",
            "read",
            "write",
            "edit",
            "message",
            "session_status",
            "web_search",
            "web_fetch"
          ]
        }
      },
      {
        "id": "rd-ship",
        "name": "RD Ship",
        "workspace": "/home/user/.openclaw/workspace-rd-ship",
        "model": {
          "primary": "openai/<GPT54_MODEL_ID>",
          "fallbacks": []
        },
        "tools": {
          "allow": [
            "read",
            "message",
            "web_search",
            "web_fetch",
            "session_status",
            "feishu_doc",
            "feishu_perm"
          ]
        }
      }
    ]
  },
  "tools": {
    "web": {
      "search": {
        "enabled": true,
        "provider": "brave",
        "apiKey": "<YOUR_BRAVE_API_KEY>"
      }
    },
    "agentToAgent": {
      "enabled": true
    }
  },
  "bindings": [
    {
      "agentId": "rd-lead",
      "match": {
        "channel": "feishu",
        "accountId": "default",
        "peer": {
          "kind": "dm",
          "id": "ou_YOUR_OPEN_ID"
        }
      }
    },
    {
      "agentId": "rd-coder",
      "match": {
        "channel": "feishu",
        "accountId": "default",
        "peer": {
          "kind": "group",
          "id": "oc_RD_CODER_CHAT_ID"
        }
      }
    },
    {
      "agentId": "rd-ship",
      "match": {
        "channel": "feishu",
        "accountId": "default",
        "peer": {
          "kind": "group",
          "id": "oc_RD_SHIP_CHAT_ID"
        }
      }
    }
  ],
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "connectionMode": "websocket",
      "dmPolicy": "allowlist",
      "groupPolicy": "open",
      "requireMention": false,
      "groupAllowFrom": [
        "ou_YOUR_OPEN_ID"
      ],
      "groups": {
        "oc_RD_CODER_CHAT_ID": {
          "enabled": true,
          "requireMention": false
        },
        "oc_RD_SHIP_CHAT_ID": {
          "enabled": true,
          "requireMention": false,
          "groupAllowFrom": "*"
        }
      },
      "tools": {
        "perm": true
      },
      "accounts": {
        "default": {
          "appId": "<YOUR_FEISHU_APP_ID>",
          "appSecret": "<YOUR_FEISHU_APP_SECRET>",
          "botName": "your-bot-name"
        }
      },
      "allowFrom": [
        "ou_YOUR_OPEN_ID"
      ],
      "dm": {
        "allowFrom": [
          "ou_YOUR_OPEN_ID"
        ]
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "<YOUR_GATEWAY_TOKEN>"
    }
  },
  "skills": {
    "install": {
      "nodeManager": "pnpm"
    }
  },
  "plugins": {
    "allow": [
      "feishu"
    ],
    "entries": {
      "feishu": {
        "enabled": true
      }
    }
  }
}
